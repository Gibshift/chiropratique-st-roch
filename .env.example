# Base de données Neon / PostgreSQL

# Ne jamais mettre les vrais identifiants dans ce fichier.

DATABASE_URI=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=verify-full
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=verify-full

# Secret Payload

# Utilisé pour sécuriser Payload CMS et les sessions.

PAYLOAD_SECRET=replace-with-a-secure-random-secret

# URL publique du site

# En local :

NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# En production, ce sera probablement :

# NEXT_PUBLIC_SERVER_URL=https://www.chiropratiquestroch.com

# Secret utilisé pour les tâches planifiées / cron

CRON_SECRET=replace-with-a-secure-random-secret

# Secret utilisé pour les aperçus Payload / preview

PREVIEW_SECRET=replace-with-a-secure-random-secret

